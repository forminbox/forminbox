{
    "name": "forminbox/forminbox",
    "description": "Standalone form and lead management plugin for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.1",
        "wp-phpunit/wp-phpunit": "^6.5",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "FormInbox\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FormInbox\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.1.99"
        },
        "sort-packages": true
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "stan": "phpstan analyse --memory-limit=1G",
        "test:unit": "phpunit -c phpunit.unit.xml.dist",
        "test:integration": "phpunit -c phpunit.integration.xml.dist",
        "check": [
            "@lint",
            "@stan",
            "@test:unit"
        ]
    }
}
